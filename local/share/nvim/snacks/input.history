# Standard English letter frequencies
ENGLISH_FREQ = {
    ' ': 15.0, 'e': 12.7, 't': 9.1, 'a': 8.1, 'o': 7.5, 'i': 7.0, 'n': 6.7,
    's': 6.3, 'h': 6.1, 'r': 6.0, 'd': 4.3, 'l': 4.0, 'c': 2.8, 'u': 2.8,
    'm': 2.4, 'w': 2.4, 'f': 2.2, 'y': 2.0, 'g': 2.0, 'p': 1.9, 'b': 1.5,
    'v': 1.0, 'k': 0.8, 'x': 0.1, 'j': 0.1, 'q': 0.1, 'z': 0.1
}

def score_character(char, is_flag_line=False):
    # For the flag line, highly reward leetspeak characters
    if is_flag_line:
        if char in b"abcdefghijklmnopqrstuvwxyz0123456789_{}":
            return 10.0
        return -50.0 # Flags generally don't contain uppercase or weird punctuation

    # For standard text lines
    if char == 32:
        return 15.0  # Spaces are extremely common
    if 65 <= char <= 90 or 97 <= char <= 122:
        # Case insensitive scoring fixes the "inverted first letter" bug!
        c = chr(char).lower()
        return ENGLISH_FREQ.get(c, 0.0)
    if char in b"_,.'\"-!?:;()":
        return 1.0
    if 32 <= char <= 126:
        return -5.0
    return -100.0 # Heavily penalize unprintable ASCII


def main():
    cipher_bytes = [bytes.fromhex(c) for c in GATHERED_ENCRYPTED]
    max_length = max(len(c) for c in cipher_bytes)

    # CONFIGURATION: We know the flag must start with this
    FLAG_PREFIX = b"crypto{"
    
    flag_line_idx = -1
    keystream = bytearray()
    
    # 1. Automatically test 'crypto{' to find the flag line and start the keystream
    for i, ct in enumerate(cipher_bytes):
        if len(ct) < len(FLAG_PREFIX): 
            continue
        
        # Derive what the keystream would be if this line was the flag
        candidate_ks = [ct[k] ^ FLAG_PREFIX[k] for k in range(len(FLAG_PREFIX))]
        
        # Test this keystream against the other sentences
        valid = True
        for j, other_ct in enumerate(cipher_bytes):
            if i == j: continue
            for k in range(min(len(FLAG_PREFIX), len(other_ct))):
                dec = other_ct[k] ^ candidate_ks[k]
                if dec < 32 or dec > 126: # Unprintable
                    valid = False
                    break
            if not valid: break
            
        if valid:
            flag_line_idx = i
            keystream.extend(candidate_ks)
            break
            
    # 2. Complete the rest of the keystream using improved frequency analysis
    for col in range(len(keystream), max_length):
        best_score = -999999
        best_byte = 0

        for guess in range(256):
            current_score = 0
            
            for i, ciphered in enumerate(cipher_bytes):
                if col < len(ciphered):
                    decrypted_char = ciphered[col] ^ guess
                    is_flag = (i == flag_line_idx)
                    current_score += score_character(decrypted_char, is_flag)
            
            if current_score > best_score:
                best_score = current_score
                best_byte = guess

        keystream.append(best_byte)

    # 3. Decrypt and output
    for i, ciphered in enumerate(cipher_bytes):
        decrypted = bytes([c ^ k for c, k in zip(ciphered, keystream)])
        try:
            decoded = decrypted.decode('ascii')
        except UnicodeDecodeError:
            decoded = decrypted.decode('ascii', errors='replace')
            
        if i == flag_line_idx:
            print(f"\n[+] SUCCESS! FLAG FOUND:\n-> {decoded}\n")
        else:
            print(f"Line {i:02d}: {decoded}")


if __name__ == "__main__":
    main()/encrypted_bytes)encrypted.encrypted_line)candidate.other_ciphered3other_ciphered_line-ciphered_line)ascii_num-ciphered_line*deciphered3candidate_keystream